# https://my.telegram.org 에서 발급
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# scripts/generate_session.py 로 1회 발급한 문자열
TELEGRAM_SESSION=

# 대시보드 인증 (DASHBOARD_PASSWORD 비어있으면 인증 비활성)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=

# === 레이트 제한 (최대 속도 모드 기본값) ===
# 각 리미트 0 = 무제한/비활성
DAILY_JOIN_LIMIT=0
HOURLY_JOIN_LIMIT=0
JOIN_DELAY_MIN=60
JOIN_DELAY_MAX=180

# 긴 휴식 (0 = 비활성)
LONG_BREAK_EVERY=0
LONG_BREAK_MIN=1800
LONG_BREAK_MAX=3600

# Quiet hours (빈 문자열 = 비활성, 형식: HH:MM-HH:MM)
QUIET_HOURS_KST=

# === 메시지 전달 (forward) 설정 — 라운드 기반 ===
# 1 라운드 = forward_enabled 그룹 전체에 1번씩 전달
# 지속 가능한 기본값 (3라운드/일 × 6시간 간격)
DAILY_ROUND_LIMIT=3
ROUND_INTERVAL_HOURS=6

# 라운드 내 그룹 간 딜레이 (burst 회피)
WITHIN_ROUND_DELAY_MIN=90
WITHIN_ROUND_DELAY_MAX=180

# 절대 안전 한도 (0 = 없음). DAILY_ROUND_LIMIT 과 별개로 계정당 총 메시지 수 제한
DAILY_FORWARD_LIMIT=0

FORWARD_INITIAL_DELAY_HOURS=24
FORWARD_FW_PAUSE_THRESHOLD=6
FORWARD_START_JITTER_MAX=300

# Railway Volume 마운트 경로
DATA_DIR=data
