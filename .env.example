# https://my.telegram.org 에서 발급
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# scripts/generate_session.py 로 1회 발급한 문자열
TELEGRAM_SESSION=

# 대시보드 인증 (DASHBOARD_PASSWORD 비어있으면 인증 비활성)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=

# === 레이트 제한 (대용량 리스트 안전 기본값) ===
DAILY_JOIN_LIMIT=12
HOURLY_JOIN_LIMIT=3
JOIN_DELAY_MIN=240
JOIN_DELAY_MAX=540

# N건 가입마다 긴 휴식 (사람처럼)
LONG_BREAK_EVERY=5
LONG_BREAK_MIN=1800
LONG_BREAK_MAX=3600

# Quiet hours (KST 기준, HH:MM-HH:MM). 이 시간엔 가입 안 함
QUIET_HOURS_KST=02:00-09:00

# Railway Volume 마운트 경로
DATA_DIR=data
