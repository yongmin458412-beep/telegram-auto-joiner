# https://my.telegram.org 에서 발급
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# scripts/generate_session.py 로 1회 발급한 문자열
TELEGRAM_SESSION=

# 대시보드 인증 (DASHBOARD_PASSWORD가 비어있으면 인증 비활성)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=

# 레이트 제한
DAILY_JOIN_LIMIT=20
JOIN_DELAY_MIN=30
JOIN_DELAY_MAX=60

# Railway Volume 마운트 경로 (기본: data)
DATA_DIR=data
