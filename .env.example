# https://my.telegram.org 에서 발급
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# scripts/generate_session.py 로 1회 발급한 문자열
TELEGRAM_SESSION=

# 대시보드 인증 (DASHBOARD_PASSWORD 비어있으면 인증 비활성)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=

# === 레이트 제한 (최대 속도 모드 기본값) ===
# 각 리미트 0 = 무제한/비활성
DAILY_JOIN_LIMIT=0
HOURLY_JOIN_LIMIT=0
JOIN_DELAY_MIN=60
JOIN_DELAY_MAX=180

# 긴 휴식 (0 = 비활성)
LONG_BREAK_EVERY=0
LONG_BREAK_MIN=1800
LONG_BREAK_MAX=3600

# Quiet hours (빈 문자열 = 비활성, 형식: HH:MM-HH:MM)
QUIET_HOURS_KST=

# Railway Volume 마운트 경로
DATA_DIR=data
